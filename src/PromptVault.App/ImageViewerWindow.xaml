<Window x:Class="PromptVault.App.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="查看图片" WindowState="Maximized" WindowStyle="None" Background="#F505080D"
        KeyDown="WindowKeyDown" MouseWheel="ViewerMouseWheel" MouseLeftButtonDown="ViewerMouseDown"
        MouseLeftButtonUp="ViewerMouseUp" MouseMove="ViewerMouseMove">
  <Grid ClipToBounds="True">
    <Image x:Name="ViewerImage" Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
      <Image.RenderTransform>
        <TransformGroup><ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1" /><TranslateTransform x:Name="ImageTranslate" /></TransformGroup>
      </Image.RenderTransform>
    </Image>
    <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,22,0,0" Background="#B8182636" CornerRadius="18" Padding="16,8">
      <TextBlock Foreground="White" Text="滚轮缩放 · 拖动查看 · Esc 关闭" />
    </Border>
    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,24,0" Content="关闭" Click="CloseClick" />
  </Grid>
</Window>
