<Window x:Class="PromptVault.App.CaptureWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="收录图片" Width="440" Height="780" WindowStyle="None" ResizeMode="NoResize"
 ShowActivated="False" Topmost="True" Background="Transparent" AllowsTransparency="True" KeyDown="OnKeyDown">
 <Border Background="#F20F1722" BorderBrush="#4056D6FF" BorderThickness="1" CornerRadius="18" Padding="18" MouseLeftButtonDown="CaptureDragMouseDown">
  <Border.Effect><DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#88000000"/></Border.Effect>
  <Grid>
   <Grid.RowDefinitions>
    <RowDefinition Height="Auto"/><RowDefinition Height="230"/><RowDefinition Height="Auto"/>
    <RowDefinition Height="130"/><RowDefinition Height="Auto"/><RowDefinition Height="90"/>
    <RowDefinition Height="58"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
   </Grid.RowDefinitions>
   <Grid Grid.Row="0" Margin="0,0,0,12" Background="Transparent" MouseLeftButtonDown="CaptureDragMouseDown">
    <TextBlock Text="新图片待收录" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
    <Button Content="×" Width="36" Height="32" Padding="0" HorizontalAlignment="Right" Click="CancelClick"/>
   </Grid>
   <Border Grid.Row="1" x:Name="PreviewDropZone" CornerRadius="12" Background="#080C12" ClipToBounds="True"
    AllowDrop="True" DragEnter="CapturePreviewDragEnter" DragOver="CapturePreviewDragEnter" DragLeave="CapturePreviewDragLeave" Drop="CapturePreviewDrop">
    <Grid>
     <Image x:Name="PreviewImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
     <Button Panel.ZIndex="3" HorizontalAlignment="Right" VerticalAlignment="Top" Width="54" Height="34" Margin="0,10,10,0" Padding="0" Background="#C63A1722" BorderBrush="#A95D6E" Content="删除" ToolTip="删除当前待收录图片" Click="DeletePendingClick"/>
     <Border x:Name="PreviewDropGlow" Visibility="Collapsed" Opacity="0" Background="#B40C2231" BorderBrush="#56D6FF" BorderThickness="2" CornerRadius="12" RenderTransformOrigin="0.5,0.5">
      <Border.RenderTransform><ScaleTransform x:Name="PreviewDropScale" ScaleX="0.98" ScaleY="0.98"/></Border.RenderTransform>
      <Border.Effect><DropShadowEffect x:Name="PreviewGlowEffect" Color="#56D6FF" BlurRadius="30" ShadowDepth="0" Opacity="0.9"/></Border.Effect>
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
       <TextBlock Text="＋" FontSize="40" HorizontalAlignment="Center" Foreground="#56D6FF"/>
       <TextBlock Text="释放以替换图片" FontSize="17" FontWeight="SemiBold" Foreground="#EEF6FF"/>
      </StackPanel>
     </Border>
    </Grid>
   </Border>
   <TextBlock Grid.Row="2" x:Name="StateText" Margin="0,10,0,6" Foreground="{StaticResource AccentBrush}" Text="等待你复制提示词…"/>
   <TextBox Grid.Row="3" x:Name="PromptBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
   <TextBlock Grid.Row="4" Text="备注" Margin="0,10,0,5" Foreground="{StaticResource SecondaryTextBrush}"/>
   <TextBox Grid.Row="5" x:Name="NotesBox" AcceptsReturn="True" TextWrapping="Wrap"/>
   <Grid Grid.Row="6" Margin="0,12,0,0">
    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
    <ComboBox x:Name="CategoryBox" Height="42" DisplayMemberPath="Name" SelectedValuePath="Id"/>
    <TextBox Grid.Column="2" x:Name="TagsBox" Height="42" VerticalContentAlignment="Center" ToolTip="标签用逗号分隔"/>
   </Grid>
   <TextBlock Grid.Row="7" x:Name="ErrorText" Margin="0,10,0,0" Foreground="#FF758F" TextWrapping="Wrap"/>
   <Grid Grid.Row="9" Margin="0,18,0,0">
    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}" Text="Enter 保存 · Esc 取消"/>
    <Button x:Name="SaveButton" HorizontalAlignment="Right" Background="{StaticResource AccentBrush}" Foreground="#061019" FontWeight="Bold" Content="保存" Click="SaveClick"/>
   </Grid>
  </Grid>
 </Border>
</Window>